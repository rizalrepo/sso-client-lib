{
    "name": "rizalrepo/sso-client",
    "description": "UNISM SSO Client SDK — Laravel + JavaScript + PHP native",
    "version": "2.1.1",
    "type": "laravel-package",
    "homepage": "https://github.com/rizalrepo/sso-client-lib",
    "support": {
        "issues": "https://github.com/rizalrepo/sso-client-lib/issues",
        "source": "https://github.com/rizalrepo/sso-client-lib"
    },
    "require": {
        "php": "^8.1",
        "ext-json": "*"
    },
    "suggest": {
        "laravel/framework": "Auto-registers SSO routes and config via ServiceProvider"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Rizalrepo\\SsoClient\\": [
                "packages/php-native/src/",
                "packages/php-laravel/src/"
            ]
        }
    },
    "authors": [
        {
            "name": "rizalrepo",
            "email": "rizalyusei@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "extra": {
        "laravel": {
            "providers": [
                "Rizalrepo\\SsoClient\\SSOClientServiceProvider"
            ]
        }
    }
}
